generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant ─────────────────────────────────────────

enum TenantPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

model Tenant {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  logo      String?
  plan      TenantPlan @default(FREE)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users         User[]
  notifications Notification[]
  storageFiles  StorageFile[]
  auditLogs     AuditLog[]
  projects      Project[]
  simulations            Simulation[]
  aiTokenQuota           AiTokenQuota?
  recruitmentCampaigns   RecruitmentCampaign[]

  @@map("tenants")
}

// ─── Users ────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  MENTOR
  MEMBER
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  firstName    String
  lastName     String
  avatar       String?
  role         UserRole @default(MEMBER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Email verification
  emailVerifiedAt         DateTime?
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?

  // Password reset
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  // Account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // OAuth
  googleId String? @unique

  // Two-Factor Authentication
  twoFactorEnabled    Boolean  @default(false)
  twoFactorSecret     String?
  twoFactorBackupCodes String[] @default([])

  // GDPR
  gdprConsentAt        DateTime?
  gdprConsentIp        String?
  gdprConsentUserAgent String?

  // Profile
  profileCompleted Boolean @default(false)
  language         String? @default("fr")
  experienceLevel  String?
  bio              String?
  phone            String?
  jobTitle         String?

  // Settings - Preferences
  profileVisibility    Boolean @default(true)
  timezone             String? @default("europe_paris")
  dateFormat           String? @default("dd_mm_yyyy")
  simulationViewMode   String? @default("modal")
  showSimulationNames  Boolean @default(true)
  showLinkedReports    Boolean @default(true)
  emailVisibility      Boolean @default(true)

  // Settings - Appearance
  sidebarTransparent   Boolean @default(false)

  // Settings - Notifications
  notifEmail           Boolean @default(true)
  notifBrowser         Boolean @default(false)
  notifDesktopLevel    String? @default("important")
  notifEmailLevel      String? @default("unread")
  notifAutoSubscribe   Boolean @default(true)

  // Settings - Layout
  layoutPreference     String? @default("layout-6")

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  refreshTokens    RefreshToken[]
  notifications    Notification[]
  storageFiles     StorageFile[]
  auditLogs        AuditLog[]
  projects         Project[]          @relation("UserProjects")
  simulations      Simulation[]       @relation("UserSimulations")
  scenariosCreated Scenario[]         @relation("ScenariosCreated")
  userProfile      UserProfile?
  competencyBadges CompetencyBadge[]
  campaignsCreated RecruitmentCampaign[] @relation("RecruiterCampaigns")
  candidateResults CandidateResult[]     @relation("CandidateResults")
  mentorReviews    MentorReview[]        @relation("MentorReviews")
  mentorSessions   MentoringSession[]    @relation("MentorSessions")
  learnerSessions  MentoringSession[]    @relation("LearnerSessions")

  @@index([tenantId])
  @@index([email])
  @@index([googleId])
  @@map("users")
}

// ─── User Profile (EPIC 2 — Profiling) ────────────────────

enum ProfileType {
  ZERO_EXPERIENCE
  BEGINNER
  RECONVERSION
  REINFORCEMENT
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  tenantId  String   @map("tenant_id")

  // Ingestion data
  linkedinData      Json?     @map("linkedin_data")
  cvData            Json?     @map("cv_data")
  cvFileUrl         String?   @map("cv_file_url")
  questionnaireData Json?     @map("questionnaire_data")
  aptitudeTestData  Json?     @map("aptitude_test_data")

  // Diagnosis
  profileType       ProfileType?  @map("profile_type")
  diagnosticData    Json?         @map("diagnostic_data")
  skills            Json?         // Array of { name, currentLevel, targetLevel, gap }
  suggestedSector   String?       @map("suggested_sector")
  selectedSector    String?       @map("selected_sector")
  suggestedDifficulty String?     @map("suggested_difficulty")

  // Custom project
  customProjectData Json?         @map("custom_project_data")

  // Status
  onboardingStep    String?       @default("not_started") @map("onboarding_step")
  completedAt       DateTime?     @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("user_profiles")
}

// ─── Auth ─────────────────────────────────────────────────

model RefreshToken {
  id         String    @id @default(cuid())
  token      String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  rememberMe Boolean   @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── Domain Events ────────────────────────────────────────

model DomainEvent {
  id            String   @id @default(cuid())
  type          String
  aggregateType String
  aggregateId   String
  data          Json
  metadata      Json
  tenantId      String?
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  consumers DomainEventConsumer[]

  @@index([type, occurredAt])
  @@index([aggregateType, aggregateId])
  @@index([tenantId])
  @@map("domain_events")
}

model DomainEventConsumer {
  id           String    @id @default(cuid())
  eventId      String
  event        DomainEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  consumerName String
  status       String    @default("PENDING")
  processedAt  DateTime?
  errorMessage String?
  retryCount   Int       @default(0)

  @@unique([eventId, consumerName])
  @@index([consumerName, status])
  @@map("domain_event_consumers")
}

// ─── Audit ──────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  entity       String   @default("SYSTEM")
  entityId     String?
  ip           String?
  userAgent    String?
  oldValue     Json?
  newValue     Json?
  metadata     Json?
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  userId   String?
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Notifications ────────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  eventId    String?
  type       String
  category   String    @default("system")
  title      String
  body       String
  data       Json?
  priority   Int       @default(1)
  readAt     DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, archivedAt])
  @@index([tenantId])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Storage ──────────────────────────────────────────────

model StorageFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  bucket       String
  path         String
  createdAt    DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("storage_files")
}

// ─── Scenarios & Simulations ─────────────────────────────

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  FAILED
}

enum SimulationStatus {
  DRAFT
  ONBOARDING
  IN_PROGRESS
  PAUSED
  COMPLETED
  ABANDONED
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ScenarioType {
  GREENFIELD
  BROWNFIELD
}

enum Sector {
  IT
  CONSTRUCTION
  MARKETING
  HEALTHCARE
  FINANCE
  CUSTOM
}

enum PhaseType {
  INITIATION
  PLANNING
  EXECUTION
  MONITORING
  CLOSURE
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  ACCEPTED
  REJECTED
}

enum RandomEventType {
  RISK
  OPPORTUNITY
  CONSTRAINT
  STAKEHOLDER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Templates (Scenarios) ──────────────────────────────

model Scenario {
  id                     String       @id @default(cuid())
  title                  String
  description            String?      @db.Text
  objectives             String[]
  sector                 Sector       @default(IT)
  difficulty             Difficulty   @default(BEGINNER)
  scenarioType           ScenarioType @default(GREENFIELD) @map("scenario_type")
  startingPhaseOrder     Int          @default(0) @map("starting_phase_order")
  brownfieldContext       Json?        @map("brownfield_context") // { previousDecisions[], completedDeliverables[], accumulatedDelays, budgetUsed, knownRisks[], teamMorale, previousPmNotes }
  estimatedDurationHours Int          @default(4)
  requiredPlan           TenantPlan   @default(FREE)
  competencies           String[]
  projectTemplate        Json         // { name, client, sector, description, teamSize, initialBudget, deadlineDays, deliverables[] }
  initialKpis            Json         // { budget: 100, schedule: 100, quality: 80, teamMorale: 75, riskLevel: 20 }
  isPublished            Boolean      @default(false)
  isArchived             Boolean      @default(false)

  createdById String
  createdBy   User   @relation("ScenariosCreated", fields: [createdById], references: [id])

  phases               ScenarioPhase[]
  simulations          Simulation[]
  recruitmentCampaign  RecruitmentCampaign? @relation("CampaignScenario")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sector, difficulty])
  @@index([scenarioType])
  @@index([isPublished])
  @@map("scenarios")
}

model ScenarioPhase {
  id                 String    @id @default(cuid())
  scenarioId         String
  scenario           Scenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  order              Int
  name               String
  description        String?   @db.Text
  type               PhaseType
  durationDays       Int       @default(5)
  completionCriteria Json?     // { requiredMeetings: 1, requiredDecisions: 1 }

  meetingTemplates     MeetingTemplate[]
  decisionTemplates    DecisionTemplate[]
  randomEventTemplates RandomEventTemplate[]

  @@unique([scenarioId, order])
  @@index([scenarioId])
  @@map("scenario_phases")
}

model MeetingTemplate {
  id              String        @id @default(cuid())
  phaseId         String
  phase           ScenarioPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  title           String
  description     String?       @db.Text
  type            String        @default("STEERING") // KICKOFF | STANDUP | STEERING | RETROSPECTIVE | CRISIS | CUSTOM
  objectives      String[]
  durationMinutes Int           @default(30)
  participants    Json          // [{ name, role, personality, cooperationLevel }]

  @@index([phaseId])
  @@map("meeting_templates")
}

model DecisionTemplate {
  id               String        @id @default(cuid())
  phaseId          String
  phase            ScenarioPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  title            String
  context          String        @db.Text
  options          Json          // [{ label, description, kpiImpact: { budget, schedule, quality, teamMorale, riskLevel } }]
  optimalOption    Int?
  timeLimitSeconds Int?

  @@index([phaseId])
  @@map("decision_templates")
}

model RandomEventTemplate {
  id                String          @id @default(cuid())
  phaseId           String
  phase             ScenarioPhase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  type              RandomEventType
  title             String
  description       String          @db.Text
  severity          Severity        @default(MEDIUM)
  probability       Float           @default(0.3)
  options           Json            // [{ label, description, kpiImpact }]
  triggerConditions Json?           // { minBudget?, maxQuality?, ... }

  @@index([phaseId])
  @@map("random_event_templates")
}

// ─── Instances (Projects & Simulations) ──────────────────

model Project {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation("UserProjects", fields: [userId], references: [id], onDelete: Cascade)
  name          String
  client        String?
  sector        Sector        @default(IT)
  description   String?       @db.Text
  initialBudget Float
  currentBudget Float
  startDate     DateTime      @default(now())
  deadline      DateTime
  status        ProjectStatus @default(NOT_STARTED)

  teamMembers  ProjectTeamMember[]
  deliverables Deliverable[]
  simulation   Simulation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@map("projects")
}

model ProjectTeamMember {
  id           String  @id @default(cuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  role         String
  expertise    String  @default("INTERMEDIATE") // JUNIOR | INTERMEDIATE | SENIOR
  personality  String  @default("COOPERATIVE") // COOPERATIVE | NEUTRAL | RESISTANT
  availability Float   @default(1.0)
  morale       Float   @default(75)
  avatar       String?

  assignedDeliverables UserDeliverable[]

  @@index([projectId])
  @@map("project_team_members")
}

model Deliverable {
  id           String           @id @default(cuid())
  projectId    String
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseOrder   Int?
  name         String
  description  String?          @db.Text
  status       DeliverableStatus @default(PENDING)
  qualityScore Float?
  dueDate      DateTime?
  deliveredAt  DateTime?
  dependencies String[]

  @@index([projectId])
  @@map("deliverables")
}

model Simulation {
  id                   String           @id @default(cuid())
  projectId            String           @unique
  project              Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenarioId           String
  scenario             Scenario         @relation(fields: [scenarioId], references: [id])
  userId               String
  user                 User             @relation("UserSimulations", fields: [userId], references: [id], onDelete: Cascade)
  tenantId             String
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status               SimulationStatus @default(DRAFT)
  currentPhaseOrder    Int              @default(0)
  startedAt            DateTime?
  completedAt          DateTime?
  totalDurationMinutes Int?

  kpis             SimulationKpi?
  kpiSnapshots     SimulationKpiSnapshot[]
  phases           SimulationPhase[]
  decisions        Decision[]
  randomEvents     RandomEvent[]
  meetings         Meeting[]
  pmoConversation  PmoConversation?
  userDeliverables UserDeliverable[]
  simulatedEmails  SimulatedEmail[]
  competencyBadges CompetencyBadge[]
  candidateResult    CandidateResult?
  mentoringSessions  MentoringSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@map("simulations")
}

// ─── Simulated Emails (EPIC 5 — Immersion Narrative) ──────

enum EmailPriority {
  URGENT
  HIGH
  NORMAL
  LOW
}

enum EmailStatus {
  UNREAD
  READ
  RESPONDED
  ARCHIVED
}

model SimulatedEmail {
  id           String     @id @default(cuid())
  simulationId String     @map("simulation_id")
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  tenantId     String     @map("tenant_id")

  // Sender info
  senderName   String     @map("sender_name")
  senderRole   String     @map("sender_role")   // DRH, Client, Fournisseur, Sponsor, DG, Membre equipe
  senderEmail  String     @map("sender_email")  // fake email

  // Email content
  subject      String
  body         String     @db.Text
  priority     EmailPriority @default(NORMAL)
  status       EmailStatus   @default(UNREAD)

  // Context
  phaseOrder   Int        @map("phase_order")
  triggerType  String?    @map("trigger_type")   // welcome, phase_start, event_reaction, decision_followup, change_request
  triggerId    String?    @map("trigger_id")

  // Response
  userResponse   String?    @db.Text @map("user_response")
  responseScore  Int?       @map("response_score")  // 0-100
  responseFeedback String?  @db.Text @map("response_feedback")
  respondedAt    DateTime?  @map("responded_at")

  // Timing
  scheduledAt  DateTime   @map("scheduled_at")
  readAt       DateTime?  @map("read_at")

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([simulationId])
  @@index([tenantId])
  @@index([simulationId, status])
  @@index([simulationId, phaseOrder])
  @@map("simulated_emails")
}

// ─── Competency Badges (EPIC 7 — Valorisation) ────────────

model CompetencyBadge {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulationId String     @map("simulation_id")
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  tenantId     String     @map("tenant_id")

  // Badge info
  title        String
  description  String     @db.Text
  scenarioTitle String    @map("scenario_title")
  sector       String
  difficulty   String

  // Scores
  globalScore  Int        @map("global_score")          // 0-100
  competencyScores Json   @map("competency_scores")     // { planification, communication, risques, leadership, rigueur, adaptabilite }

  // Debriefing
  strengths       String[] @default([])
  improvements    String[] @default([])
  recommendations String[] @default([])
  debriefingSummary String? @db.Text @map("debriefing_summary")

  // CV suggestions
  cvSuggestions   Json?    @map("cv_suggestions")

  // Sharing
  shareToken      String?  @unique @map("share_token")
  isPublic        Boolean  @default(false) @map("is_public")

  // Duration
  durationMinutes Int?     @map("duration_minutes")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([simulationId])
  @@index([tenantId])
  @@index([shareToken])
  @@map("competency_badges")
}

model SimulationKpiSnapshot {
  id           String     @id @default(cuid())
  simulationId String
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  phaseOrder   Int
  trigger      String     // "simulation_start" | "decision" | "event" | "meeting" | "phase_advance"
  triggerId    String?
  budget       Float
  schedule     Float
  quality      Float
  teamMorale   Float
  riskLevel    Float
  takenAt      DateTime   @default(now())

  @@index([simulationId])
  @@map("simulation_kpi_snapshots")
}

model SimulationKpi {
  id           String     @id @default(cuid())
  simulationId String     @unique
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  budget       Float      @default(100)
  schedule     Float      @default(100)
  quality      Float      @default(80)
  teamMorale   Float      @default(75)
  riskLevel    Float      @default(20)
  updatedAt    DateTime   @updatedAt

  @@map("simulation_kpis")
}

model SimulationPhase {
  id           String     @id @default(cuid())
  simulationId String
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  order        Int
  name         String
  type         PhaseType
  status       String     @default("LOCKED") // LOCKED | ACTIVE | COMPLETED
  startedAt    DateTime?
  completedAt  DateTime?

  @@unique([simulationId, order])
  @@index([simulationId])
  @@map("simulation_phases")
}

model Decision {
  id               String     @id @default(cuid())
  simulationId     String
  simulation       Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  phaseOrder       Int
  templateId       String?
  title            String
  context          String     @db.Text
  options          Json       // [{ label, description, kpiImpact }]
  selectedOption   Int?
  decidedAt        DateTime?
  kpiImpact        Json?
  timeLimitSeconds Int?

  @@index([simulationId])
  @@map("decisions")
}

model RandomEvent {
  id             String          @id @default(cuid())
  simulationId   String
  simulation     Simulation      @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  phaseOrder     Int
  templateId     String?
  type           RandomEventType
  title          String
  description    String          @db.Text
  severity       Severity
  options        Json
  selectedOption Int?
  resolvedAt     DateTime?
  kpiImpact      Json?

  @@index([simulationId])
  @@map("random_events")
}

// ─── Meetings ────────────────────────────────────────────

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Meeting {
  id              String        @id @default(cuid())
  simulationId    String
  simulation      Simulation    @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  phaseOrder      Int
  templateId      String?
  title           String
  description     String?       @db.Text
  type            String        @default("STEERING")
  objectives      String[]
  durationMinutes Int           @default(30)
  mode            String        @default("TEXT") // "TEXT" | "AUDIO"
  status          MeetingStatus @default(SCHEDULED)
  startedAt       DateTime?
  completedAt     DateTime?

  participants MeetingParticipant[]
  messages     MeetingMessage[]
  summary      MeetingSummary?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([simulationId])
  @@map("meetings")
}

model MeetingParticipant {
  id               String  @id @default(cuid())
  meetingId        String
  meeting          Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name             String
  role             String
  personality      String?
  cooperationLevel Int     @default(3)
  avatar           String?

  messages MeetingMessage[]

  @@index([meetingId])
  @@map("meeting_participants")
}

model MeetingMessage {
  id            String              @id @default(cuid())
  meetingId     String
  meeting       Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  participantId String?
  participant   MeetingParticipant? @relation(fields: [participantId], references: [id])
  content       String              @db.Text
  role          String              @default("USER")
  metadata      Json?
  createdAt     DateTime            @default(now())

  @@index([meetingId])
  @@map("meeting_messages")
}

model MeetingSummary {
  id           String   @id @default(cuid())
  meetingId    String   @unique
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  summary      String   @db.Text
  keyDecisions String[]
  actionItems  Json?
  kpiImpact    Json?
  createdAt    DateTime @default(now())

  @@map("meeting_summaries")
}

// ─── PMO Conversations (EPIC 3) ─────────────────────────

model PmoConversation {
  id           String     @id @default(cuid())
  simulationId String     @unique
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  messages PmoMessage[]

  @@index([simulationId])
  @@map("pmo_conversations")
}

model PmoMessage {
  id             String          @id @default(cuid())
  conversationId String
  conversation   PmoConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String          @default("user") // "user" | "assistant" | "system"
  content        String          @db.Text
  metadata       Json?           // { intent?, templateId?, deliverableId? }
  createdAt      DateTime        @default(now())

  @@index([conversationId, createdAt])
  @@map("pmo_messages")
}

// ─── User Deliverables (EPIC 4) ─────────────────────────

enum UserDeliverableStatus {
  DRAFT
  SUBMITTED
  EVALUATED
  REVISED
  PENDING_APPROVAL
  VALIDATED
  REJECTED
}

enum DeliverableDelegationType {
  SELF_PRODUCED
  DELEGATED
}

model UserDeliverable {
  id             String                @id @default(cuid())
  simulationId   String
  simulation     Simulation            @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  templateId     String?
  phaseOrder     Int
  title          String
  type           String                // charter, wbs, risk-register, etc.
  content        String?               @db.Text  // Markdown content written by learner
  status         UserDeliverableStatus @default(DRAFT)
  revisionNumber Int                   @default(0)
  maxRevisions   Int                   @default(3)
  dueDate        DateTime?
  submittedAt    DateTime?
  lastSavedAt    DateTime?
  meetingId      String?               // For meeting-minutes: linked meeting

  // Delegation (Livrables Metiers)
  delegationType     DeliverableDelegationType @default(SELF_PRODUCED) @map("delegation_type")
  assignedToMemberId String?                   @map("assigned_to_member_id")
  assignedToMember   ProjectTeamMember?        @relation(fields: [assignedToMemberId], references: [id], onDelete: SetNull)
  assignedToRole     String?                   @map("assigned_to_role") // TECHNICAL_EXPERT, HR_MANAGER, ARCHITECT, etc.

  // Approval workflow
  approvalChain   Json?      @map("approval_chain") // [{role, memberId, status: PENDING|APPROVED|REJECTED, comment?}]
  approvedBy      String?    @map("approved_by")
  approvedAt      DateTime?  @map("approved_at")
  rejectionReason String?    @db.Text @map("rejection_reason")

  evaluations          DeliverableEvaluation[]
  deliverableApprovals DeliverableApproval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([simulationId])
  @@index([simulationId, phaseOrder])
  @@index([status])
  @@index([delegationType])
  @@map("user_deliverables")
}

model DeliverableApproval {
  id              String    @id @default(cuid())
  deliverableId   String    @map("deliverable_id")
  deliverable     UserDeliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  reviewerMemberId String?  @map("reviewer_member_id") // ProjectTeamMember ID (IA agent)
  reviewerRole    String    @map("reviewer_role")      // SPONSOR, CLIENT, TECHNICAL_LEAD
  status          String    @default("PENDING")        // PENDING, APPROVED, REJECTED
  comment         String?   @db.Text
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([deliverableId])
  @@map("deliverable_approvals")
}

model DeliverableEvaluation {
  id               String          @id @default(cuid())
  deliverableId    String
  deliverable      UserDeliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  revisionNumber   Int
  score            Float           // 0-100
  grade            String          // A, B, C, D, F
  positives        String[]        // Points positifs
  improvements     String[]        // Points a ameliorer
  missingElements  String[]        // Elements manquants
  incorrectElements String[]       // Elements incorrects
  recommendations  String[]        // Recommandations
  pmiOutputsCovered String[]       // PMI outputs couverts
  pmiOutputsMissing String[]       // PMI outputs manquants
  aiGeneratedCR    String?         @db.Text  // For meeting-minutes: AI-generated version
  metadata         Json?           // Extra evaluation data
  mentorReview     MentorReview?
  createdAt        DateTime        @default(now())

  @@index([deliverableId])
  @@map("deliverable_evaluations")
}

// ─── Deliverable Templates (EPIC 1) ─────────────────────

enum DeliverableTemplateDifficulty {
  DISCOVERY
  STANDARD
  ADVANCED
}

model DeliverableTemplate {
  id                 String                       @id @default(cuid())
  tenantId           String
  title              String
  type               String                       // charter, wbs, risk-register, schedule, etc.
  phase              PhaseType
  description        String?                      @db.Text
  content            String                       @db.Text  // Markdown template
  evaluationCriteria Json                          // JSON structured criteria
  pmiProcess         String?                       // e.g. "4.1"
  difficulty         DeliverableTemplateDifficulty @default(STANDARD)
  referenceExample   String?                      @db.Text  // "perfect deliverable" Markdown
  version            Int                          @default(1)
  isActive           Boolean                      @default(true)
  createdById        String
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  versions DeliverableTemplateVersion[]

  @@index([tenantId])
  @@index([phase, type, difficulty])
  @@index([isActive])
  @@map("deliverable_templates")
}

model DeliverableTemplateVersion {
  id                 String                       @id @default(cuid())
  templateId         String
  template           DeliverableTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version            Int
  title              String
  type               String
  phase              PhaseType
  description        String?                      @db.Text
  content            String                       @db.Text
  evaluationCriteria Json
  pmiProcess         String?
  difficulty         DeliverableTemplateDifficulty
  referenceExample   String?                      @db.Text
  createdAt          DateTime                     @default(now())

  @@unique([templateId, version])
  @@index([templateId])
  @@map("deliverable_template_versions")
}

// ─── Reference Documents (EPIC 1) ───────────────────────

enum ReferenceDocumentCategory {
  TEMPLATE
  STANDARD
  BEST_PRACTICE
  GLOSSARY
}

model ReferenceDocument {
  id          String                    @id @default(cuid())
  tenantId    String
  title       String
  category    ReferenceDocumentCategory
  phase       PhaseType?                // null = all phases
  pmiProcess  String?                   // e.g. "5.19"
  content     String                    @db.Text  // Markdown
  term        String?                   // Glossary: the PMI term
  example     String?                   @db.Text  // Glossary: concrete example
  version     Int                       @default(1)
  isActive    Boolean                   @default(true)
  createdById String
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  versions ReferenceDocumentVersion[]

  @@index([tenantId])
  @@index([category, phase])
  @@index([isActive])
  @@map("reference_documents")
}

model ReferenceDocumentVersion {
  id         String                    @id @default(cuid())
  documentId String
  document   ReferenceDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int
  title      String
  category   ReferenceDocumentCategory
  phase      PhaseType?
  pmiProcess String?
  content    String                    @db.Text
  term       String?
  example    String?                   @db.Text
  createdAt  DateTime                  @default(now())

  @@unique([documentId, version])
  @@index([documentId])
  @@map("reference_document_versions")
}

// ─── AI Token Tracking ──────────────────────────────────

model AiTokenUsage {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  simulationId String?
  operation    String
  provider     String
  model        String
  inputTokens  Int
  outputTokens Int
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@map("ai_token_usage")
}

model AiTokenQuota {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monthlyInputLimit  Int      @default(500000)
  monthlyOutputLimit Int      @default(200000)
  currentMonthInput  Int      @default(0)
  currentMonthOutput Int      @default(0)
  periodStart        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("ai_token_quotas")
}

// ─── Mentoring (Premium) ─────────────────────────────────

model MentorReview {
  id               String   @id @default(cuid())
  evaluationId     String   @unique @map("evaluation_id")
  evaluation       DeliverableEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  mentorId         String   @map("mentor_id")
  mentor           User     @relation("MentorReviews", fields: [mentorId], references: [id], onDelete: Cascade)
  tenantId         String   @map("tenant_id")

  humanScore       Int      @map("human_score")       // 0-100
  leadershipScore  Int?     @map("leadership_score")  // 0-100
  diplomacyScore   Int?     @map("diplomacy_score")   // 0-100
  postureScore     Int?     @map("posture_score")     // 0-100

  feedback         String   @db.Text
  recommendations  String?  @db.Text

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([evaluationId])
  @@index([mentorId])
  @@index([tenantId])
  @@map("mentor_reviews")
}

model MentoringSession {
  id              String     @id @default(cuid())
  simulationId    String     @map("simulation_id")
  simulation      Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  mentorId        String     @map("mentor_id")
  mentor          User       @relation("MentorSessions", fields: [mentorId], references: [id], onDelete: Cascade)
  learnerId       String     @map("learner_id")
  learner         User       @relation("LearnerSessions", fields: [learnerId], references: [id], onDelete: Cascade)
  tenantId        String     @map("tenant_id")

  type            String     @default("DEBRIEFING") // DEBRIEFING, CAREER_COACHING, INTERVIEW_PREP
  status          String     @default("SCHEDULED")  // SCHEDULED, IN_PROGRESS, COMPLETED
  notes           String?    @db.Text
  scheduledAt     DateTime?  @map("scheduled_at")
  completedAt     DateTime?  @map("completed_at")

  messages        MentoringMessage[]

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([simulationId])
  @@index([mentorId])
  @@index([learnerId])
  @@index([tenantId])
  @@map("mentoring_sessions")
}

model MentoringMessage {
  id          String           @id @default(cuid())
  sessionId   String           @map("session_id")
  session     MentoringSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId    String           @map("sender_id")
  role        String           // MENTOR, LEARNER
  content     String           @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("mentoring_messages")
}

// ─── Recruitment (EPICs 8-10) ─────────────────────────────

enum CampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum CultureType {
  STRICT
  AGILE
  COLLABORATIVE
}

enum CandidateStatus {
  PENDING
  PROFILING
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model RecruitmentCampaign {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recruiterId String         @map("recruiter_id")
  recruiter   User           @relation("RecruiterCampaigns", fields: [recruiterId], references: [id], onDelete: Cascade)

  // Campaign info
  title           String
  slug            String         @unique
  status          CampaignStatus @default(DRAFT)
  jobTitle        String         @map("job_title")
  jobDescription  String         @map("job_description") @db.Text
  requiredSkills  Json           @map("required_skills")  // Array of { skill: string, weight: number }
  experienceLevel String         @map("experience_level") // junior, confirmed, senior
  projectTypes    String[]       @map("project_types")

  // Culture & customization
  culture             CultureType @default(COLLABORATIVE)
  cultureDescription  String?     @map("culture_description") @db.Text
  internalDocuments   Json?       @map("internal_documents") // Array of { fileName, fileUrl, description }

  // Deployment
  maxCandidates   Int?       @map("max_candidates")
  publishedAt     DateTime?  @map("published_at")
  closedAt        DateTime?  @map("closed_at")

  // Generated scenario
  generatedScenarioId String?   @unique @map("generated_scenario_id")
  generatedScenario   Scenario? @relation("CampaignScenario", fields: [generatedScenarioId], references: [id], onDelete: SetNull)

  candidateResults CandidateResult[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([tenantId])
  @@index([recruiterId])
  @@index([status])
  @@index([slug])
  @@map("recruitment_campaigns")
}

model CandidateResult {
  id           String              @id @default(cuid())
  campaignId   String              @map("campaign_id")
  campaign     RecruitmentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId       String              @map("user_id")
  user         User                @relation("CandidateResults", fields: [userId], references: [id], onDelete: Cascade)
  simulationId String?             @unique @map("simulation_id")
  simulation   Simulation?         @relation(fields: [simulationId], references: [id], onDelete: SetNull)

  status          CandidateStatus @default(PENDING)
  currentPhase    Int?            @map("current_phase")
  abandonedPhase  Int?            @map("abandoned_phase")

  // Scores (filled after simulation completes)
  globalScore       Int?          @map("global_score")
  hardSkillsScore   Int?          @map("hard_skills_score")
  softSkillsScore   Int?          @map("soft_skills_score")
  reliabilityScore  Int?          @map("reliability_score")
  adaptabilityScore Int?          @map("adaptability_score")
  leadershipScore   Int?          @map("leadership_score")
  competencyScores  Json?         @map("competency_scores")

  // AI Analysis (EPIC 10)
  report360        Json?          @map("report_360")        // Full 360 report data
  aiJustification  String?        @map("ai_justification") @db.Text
  strengths        String[]       @default([])
  weaknesses       String[]       @default([])
  matchPercentage  Int?           @map("match_percentage")
  interviewGuide   Json?          @map("interview_guide")   // Generated interview questions

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@map("candidate_results")
}
