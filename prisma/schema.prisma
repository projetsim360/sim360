generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant ─────────────────────────────────────────

enum TenantPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

model Tenant {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  logo      String?
  plan      TenantPlan @default(FREE)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users         User[]
  notifications Notification[]
  storageFiles  StorageFile[]
  auditLogs     AuditLog[]

  @@map("tenants")
}

// ─── Users ────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  firstName    String
  lastName     String
  avatar       String?
  role         UserRole @default(MEMBER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Email verification
  emailVerifiedAt         DateTime?
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?

  // Password reset
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  // Account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // OAuth
  googleId String? @unique

  // Two-Factor Authentication
  twoFactorEnabled    Boolean  @default(false)
  twoFactorSecret     String?
  twoFactorBackupCodes String[] @default([])

  // GDPR
  gdprConsentAt        DateTime?
  gdprConsentIp        String?
  gdprConsentUserAgent String?

  // Profile
  profileCompleted Boolean @default(false)
  language         String? @default("fr")
  experienceLevel  String?
  bio              String?
  phone            String?
  jobTitle         String?

  // Settings - Preferences
  profileVisibility    Boolean @default(true)
  timezone             String? @default("europe_paris")
  dateFormat           String? @default("dd_mm_yyyy")
  simulationViewMode   String? @default("modal")
  showSimulationNames  Boolean @default(true)
  showLinkedReports    Boolean @default(true)
  emailVisibility      Boolean @default(true)

  // Settings - Appearance
  sidebarTransparent   Boolean @default(false)

  // Settings - Notifications
  notifEmail           Boolean @default(true)
  notifBrowser         Boolean @default(false)
  notifDesktopLevel    String? @default("important")
  notifEmailLevel      String? @default("unread")
  notifAutoSubscribe   Boolean @default(true)

  // Settings - Layout
  layoutPreference     String? @default("layout-6")

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  refreshTokens RefreshToken[]
  notifications Notification[]
  storageFiles  StorageFile[]
  auditLogs     AuditLog[]

  @@index([tenantId])
  @@index([email])
  @@index([googleId])
  @@map("users")
}

// ─── Auth ─────────────────────────────────────────────────

model RefreshToken {
  id         String    @id @default(cuid())
  token      String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  rememberMe Boolean   @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── Domain Events ────────────────────────────────────────

model DomainEvent {
  id            String   @id @default(cuid())
  type          String
  aggregateType String
  aggregateId   String
  data          Json
  metadata      Json
  tenantId      String?
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  consumers DomainEventConsumer[]

  @@index([type, occurredAt])
  @@index([aggregateType, aggregateId])
  @@index([tenantId])
  @@map("domain_events")
}

model DomainEventConsumer {
  id           String    @id @default(cuid())
  eventId      String
  event        DomainEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  consumerName String
  status       String    @default("PENDING")
  processedAt  DateTime?
  errorMessage String?
  retryCount   Int       @default(0)

  @@unique([eventId, consumerName])
  @@index([consumerName, status])
  @@map("domain_event_consumers")
}

// ─── Audit ──────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  entity       String   @default("SYSTEM")
  entityId     String?
  ip           String?
  userAgent    String?
  oldValue     Json?
  newValue     Json?
  metadata     Json?
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  userId   String?
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Notifications ────────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  eventId    String?
  type       String
  category   String    @default("system")
  title      String
  body       String
  data       Json?
  priority   Int       @default(1)
  readAt     DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, archivedAt])
  @@index([tenantId])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Storage ──────────────────────────────────────────────

model StorageFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  bucket       String
  path         String
  createdAt    DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("storage_files")
}
