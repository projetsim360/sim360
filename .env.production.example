# ─── Application ───────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_PREFIX=api/v1
APP_URL=https://app.sim360.dev
API_URL=https://api.sim360.dev

# ─── Database (PostgreSQL) ─────────────────────────────────
# For docker-compose.prod.yml, DATABASE_URL is set automatically.
# For Railway/external DB, set this directly:
DATABASE_URL=postgresql://user:password@host:5432/sim360_prod

# Docker Compose specific:
POSTGRES_USER=sim360
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sim360_prod

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── JWT Auth (MUST change in production!) ─────────────────
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_RANDOM
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ─── 2FA Encryption ───────────────────────────────────────
TWO_FACTOR_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_HEX_KEY

# ─── AI Providers ─────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_DEFAULT_PROVIDER=anthropic

# ─── Google Cloud Storage ─────────────────────────────────
GCS_BUCKET=sim360-prod
GCS_PROJECT_ID=
GCS_KEY_FILE=

# ─── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sim360.dev

# ─── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.sim360.dev/api/v1/auth/google/callback

# ─── Firebase Cloud Messaging ─────────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ─── Docker Compose Ports (optional overrides) ────────────
API_PORT=3001
WEBAPP_PORT=80
VITE_API_URL=/api/v1
